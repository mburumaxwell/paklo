{
  "name": "extension-azure-devops",
  "version": "2.68.0",
  "description": "Dependabot Azure DevOps (Paklo) task",
  "license": "AGPL-3.0-later",
  "author": "mburumaxwell",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsdown --watch",
    "typecheck": "tsc",
    "prebuild": "tsc",
    "build": "tsdown",
    "start": "pnpm start:dependabot:V2",
    "start:dependabot:V1": "node tasks/dependabot/dependabotV1/dist/index.js",
    "start:dependabot:V2": "node tasks/dependabot/dependabotV2/dist/index.js",
    "start:metadata": "node tasks/metadata/DependabotFetchMetadataV1/dist/index.js",
    "test": "vitest",
    "clean": "rimraf .turbo dist tasks/dependabot/dependabotV1/dist tasks/dependabot/dependabotV2/dist tasks/metadata/DependabotFetchMetadataV1/dist",
    "packages:version": "node scripts/update-versions.mjs",
    "package": "pnpm tfx extension create --json5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mburumaxwell/paklo.git",
    "directory": "extensions/azure"
  },
  "keywords": [
    "dependabot",
    "azure",
    "devops"
  ],
  "bugs": {
    "url": "https://github.com/mburumaxwell/paklo/issues"
  },
  "homepage": "https://github.com/mburumaxwell/paklo#readme",
  "dependencies": {
    "@paklo/core": "workspace:*",
    "azure-pipelines-task-lib": "5.2.10",
    "semver": "7.8.0"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@types/semver": "7.7.1",
    "tfx-cli": "0.23.1",
    "tsdown": "0.22.0"
  }
}
