{
  "name": "@paklo/core",
  "version": "0.17.1",
  "sideEffects": false,
  "type": "module",
  "author": "mburumaxwell",
  "license": "AGPL-3.0-later",
  "exports": {
    "./logger": {
      "types": "./dist/logger.d.mts",
      "import": "./dist/logger.mjs"
    },
    "./github": {
      "types": "./dist/github/index.d.mts",
      "import": "./dist/github/index.mjs"
    },
    "./dependabot": {
      "types": "./dist/dependabot/index.d.mts",
      "import": "./dist/dependabot/index.mjs"
    },
    "./local": {
      "types": "./dist/local/index.d.mts",
      "import": "./dist/local/index.mjs"
    },
    "./runner": {
      "types": "./dist/runner/index.d.mts",
      "import": "./dist/runner/index.mjs"
    },
    "./azure": {
      "types": "./dist/azure/index.d.mts",
      "import": "./dist/azure/index.mjs"
    },
    "./azure/client": {
      "types": "./dist/azure/client/index.d.mts",
      "import": "./dist/azure/client/index.mjs"
    },
    "./azure/config": {
      "types": "./dist/azure/config.d.mts",
      "import": "./dist/azure/config.mjs"
    },
    "./azure/runner": {
      "types": "./dist/azure/runner/index.d.mts",
      "import": "./dist/azure/runner/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "typecheck": "tsc",
    "build": "tsdown",
    "test": "vitest",
    "scripts:fetch-images": "tsx src/runner/fetch-images.ts",
    "scripts:cleanup-docker": "tsx src/runner/cleanup-docker.ts",
    "scripts:update-container-manifest": "tsx src/runner/update-containers.ts",
    "clean": "rimraf .turbo dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mburumaxwell/paklo.git",
    "directory": "packages/core"
  },
  "keywords": [
    "dependabot",
    "azure",
    "devops",
    "paklo"
  ],
  "bugs": {
    "url": "https://github.com/mburumaxwell/paklo/issues"
  },
  "homepage": "https://github.com/mburumaxwell/paklo#readme",
  "dependencies": {
    "@hono/node-server": "1.19.14",
    "@hono/zod-validator": "0.7.6",
    "dockerode": "4.0.10",
    "hono": "4.12.14",
    "js-yaml": "4.1.1",
    "ky": "2.0.1",
    "node-forge": "1.4.0",
    "octokit": "5.0.5",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "semver": "7.7.4",
    "tar-stream": "3.1.8",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/dockerode": "4.0.1",
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.6.0",
    "@types/node-forge": "1.3.14",
    "@types/semver": "7.7.1",
    "@types/tar-stream": "3.1.4",
    "tsdown": "0.21.9",
    "tsx": "4.21.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
