{
  "name": "paklo",
  "version": "0.0.0",
  "license": "AGPL-3.0-later",
  "author": "mburumaxwell",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",

    "changeset": "changeset",
    "packages:version": "changeset version && turbo run packages:version",
    "packages:publish": "changeset publish",

    "web:start": "turbo run start --filter=web...",
    "web:dev": "turbo run dev --filter=web...",
    "web:build": "turbo run build --filter=web...",
    "web:clean": "turbo run clean --filter=web...",

    "extensions-azure:start": "turbo run start --filter=extension-azure-devops...",
    "extensions-azure:build": "turbo run build --filter=extension-azure-devops...",

    "typecheck": "turbo run typecheck",
    "codegen": "turbo run codegen",
    "build": "turbo run build",
    "test": "turbo run test",
    "package": "turbo run package",
    "clean": "turbo run clean && rimraf .turbo"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "portless": "0.10.1",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "turbo": "2.9.5",
    "typescript": "6.0.2",
    "vite": "8.0.7",
    "vitest": "4.1.3"
  },
  "packageManager": "pnpm@10.27.0"
}
