  "private": true,
  "scripts": {
    "ui-gen": "pnpm exec shadcn add --overwrite accordion alert alert-dialog avatar badge breadcrumb button-group dialog card calendar chart checkbox collapsible combobox command dropdown-menu empty field input-group item navigation-menu pagination popover progress radio-group scroll-area select separator sheet sidebar skeleton sonner spinner table tabs textarea toggle toggle-group tooltip --overwrite",
    "ui-diff": "pnpm run ui-gen-base --diff",
    "prisma": "pnpm exec prisma",
    "prisma-gen": "pnpm exec prisma generate --no-hints",
    "prisma-push": "pnpm exec prisma db push",
    "prisma-studio": "pnpm exec prisma studio",
    "prisma-format": "pnpm exec prisma format",
    "auth-gen": "pnpm exec auth generate",
    "email-dev": "email dev --dir src/emails/templates --port 4001",
    "workflow-web": "workflow web",
    "codegen": "pnpm prisma-gen",
    "typegen": "next typegen && pnpm codegen",
    "build": "next build",
    "dev": "portless run next dev",
    "start": "next start",
    "test": "vitest",
    "clean": "rimraf .turbo .next .source .react-email .generated src/app/.well-known/workflow out"
  },
