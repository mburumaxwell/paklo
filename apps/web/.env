# OTEL_LOG_LEVEL="info"

# CRON_SECRET="your-cron-secret"
# RESEND_API_KEY="your-resend-api-key"
MONGO_URL="mongodb://localhost:27017/paklo"
NEXT_PUBLIC_HELP_SCOUT_BEACON_ID="77eb2e2c-9cc3-4d83-8b42-2354bfbc9d87"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/paklo"
SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/paklo_shadow"

# vercel-flags configuration
FLAGS="vf_server_....."
VERCEL_EXPERIMENTAL_EMBED_FLAG_DEFINITIONS=1

# Better Auth variables
BETTER_AUTH_SECRET="your-secret-key-must-be-at-least-32-characters-long"
ENTRAID_CLIENT_ID="your-entra-id-client-id"
ENTRAID_CLIENT_SECRET="your-entra-id-client-secret"

# Stripe config variables
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"

# Azure config variables (for Managed Identity and resource access)
# AZURE_TENANT_ID="your-azure-tenant-id"
# AZURE_CLIENT_ID="your-azure-client-id"
AZURE_SUBSCRIPTION_ID="your-azure-subscription-id"
AZURE_RESOURCE_GROUP_JOBS="your-azure-resource-group-for-jobs"

# Upstash is automatically configured with KV_REST_API_* variables when deployed to Vercel
# UPSTASH_REDIS_REST_URL="https://your-instance-name.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-api-token"
# REDIS_CACHE_HOSTNAME="your-instance-name.uksouth.redis.azure.net"
# TODO: remove these once we have provisioned Upstash
KV_REST_API_URL="https://your-instance-name.upstash.io"
KV_REST_API_TOKEN="your-upstash-rest-api-token"
